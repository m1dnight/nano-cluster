+%% @hidden
+%% @doc Tear down the connection currently registered as alive for `Node'.
+%%
+%% Called by `dist_util' when an incoming handshake supersedes an existing
+%% connection: our side answered `<<"alive">>' and the peer answered
+%% `<<"true">>', meaning it has dropped the old connection and wants a fresh
+%% one. Our side must drop its stale connection *before* the new handshake
+%% reaches `erlang:setnode/3', otherwise `setnode/3' raises `badarg' because a
+%% live connection to `Node' with the same creation still exists (the peer's VM
+%% never restarted, only its socket dropped, so its node creation is unchanged).
+%%
+%% Killing the old dist controller process makes its resource-down handler
+%% clear the C-side dist entry (see `dist_connection_down' in `dist_nifs.c'), so
+%% the superseding `setnode/3' can reuse it. The handshake then runs a full
+%% challenge round-trip before `setnode/3', which is ample time for the local
+%% controller to die and fire that handler.
+-spec disconnect_old_connection(pid(), node()) -> ok.
+disconnect_old_connection(Kernel, Node) ->
+    gen_server:call(Kernel, {disconnect_old_connection, Node}).
+
